# Twilio credentials
# Copy this file to .env and fill in the real values locally.
# Do NOT commit the real .env file.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# For SMS, use format:
# TWILIO_PHONE_NUMBER=+15555555555
#
# For WhatsApp sandbox, use format:
# TWILIO_PHONE_NUMBER=whatsapp:+14155238886
TWILIO_PHONE_NUMBER=

# Local testing only.
# Used when running rasa shell because the shell sender_id is not a real phone number.
#
# For SMS:
# TEST_USER_PHONE=+15555555555
#
# For WhatsApp:
# TEST_USER_PHONE=whatsapp:+15555555555
TEST_USER_PHONE=
